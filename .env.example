# Roadmap OS Environment Variables

# -----------------------------------------------------------------------------
# Local Development (Frontend)
# -----------------------------------------------------------------------------
# These variables are exposed to the Vite React frontend.
# When running locally, set VITE_SYNC_API_URL to your Vercel dev URL (e.g., http://localhost:3000/api/sync)
# When deployed to Vercel, leave it empty or map it to `/api/sync` to use relative paths.
VITE_SYNC_API_URL="/api/sync"

# This is the secure token the frontend will send in the Authorization header.
# Generate a random secure string (e.g., using `openssl rand -hex 32`)
VITE_SYNC_AUTH_TOKEN="your_secure_random_token_here"


# -----------------------------------------------------------------------------
# Backend / Vercel Serverless Functions
# -----------------------------------------------------------------------------
# These variables are ONLY used by the Vercel backend. Do NOT prefix with VITE_.

# The Neon Postgres database connection string
DATABASE_URL="postgres://username:password@ep-cool-darkness-123456.us-east-2.aws.neon.tech/neondb?sslmode=require"

# The same secure token used by the frontend, so the backend can verify requests.
SYNC_AUTH_TOKEN="your_secure_random_token_here"
